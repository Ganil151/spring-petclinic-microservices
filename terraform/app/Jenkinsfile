pipeline {
    agent { label params.NODE_LABEL }

    environment {
        COMPOSE_PROJECT_NAME = "spring-petclinic"
        DOCKER_PREFIX      = "ganil151" 
        IMAGE_TAG          = "${env.BUILD_NUMBER ?: 'latest'}"
        JAVA_HOME          = "/usr/lib/jvm/java-21-amazon-corretto" 
        PATH               = "${JAVA_HOME}/bin:${env.PATH}"
    }

    parameters {
        string(
            name: 'NODE_LABEL',
            defaultValue: 'worker-node-1',
            description: 'Label of the Jenkins worker node to run this pipeline'
        )
    }

    triggers {
        githubPush()
    }

    stages {
        stage('Checkout') {
            steps {
                git(
                    branch: 'main',
                    credentialsId: 'github-credentials',
                    url: 'https://github.com/Ganil151/spring-petclinic-microservices.git'
                )
            }
        }
        
        stage('Configure Docker Permissions') {
            steps {
                sh '''
                echo "Configuring Docker permissions for the current user..."
                CURRENT_USER=$(whoami)
                
                if ! grep -q "^docker:" /etc/group; then
                    echo "Creating 'docker' group..."
                    sudo groupadd docker
                fi

                echo "Adding user $CURRENT_USER to the 'docker' group."
                # Note: This requires a new login/shell to take effect, but we try anyway.
                sudo usermod -aG docker $CURRENT_USER

                if ! systemctl is-active --quiet docker; then
                    echo "Starting Docker service..."
                    sudo systemctl start docker
                fi
                
                echo "Docker status check:"
                sudo systemctl status docker | grep 'Active:'
                '''
            }
        }

        stage('Normalize Line Endings') {
            steps {
                sh '''
                echo "Converting mvnw line endings from CRLF (DOS) to LF (Unix)..."
                sed -i 's/\r$//' mvnw
                '''
            }
        }

        stage('Install yq') {
            steps {
                sh '''
                if ! command -v yq &> /dev/null; then
                    echo "Installing yq..."
                    sudo wget https://github.com/mikefarah/yq/releases/download/v4.34.1/yq_linux_amd64 -O /usr/local/bin/yq
                    sudo chmod +x /usr/local/bin/yq
                fi
                yq --version
                '''
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh '''
                    echo "Logging into Docker Hub..."
                    echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                    '''
                }
            }
        }

        stage('Build and Push All Microservice Images') {
            steps {
                sh '''
                echo "--- Starting Application Build and Push ---"
                
                chmod +x mvnw
                java -version
                
                # ONLY RUNNING THE TAGGED BUILD WITH -e FLAG FOR DETAILED STACK TRACE
                echo "Running Maven build with -e (stack trace) flag..."
                /bin/bash ./mvnw clean install -P buildDocker -e -Ddocker.image.prefix=${DOCKER_PREFIX} -Ddocker.image.tag=${IMAGE_TAG}
                '''
            }
            post {
                success { 
                    echo "======== All Microservice Images Built & Pushed ⭐Successfully⭐ ========" 
                    // This will not run on failure, but is good practice:
                    // /bin/bash ./mvnw clean install -P buildDocker -Ddocker.image.prefix=${DOCKER_PREFIX} -Ddocker.image.tag=latest
                }
                failure { 
                    echo "======== Microservice Image Build failed❌. PLEASE PROVIDE THE FULL STACK TRACE. ========" 
                }
            }
        }

        stage('Update Compose File Image Names') {
            steps {
                sh '''
                echo "Skipping due to prior failure."
                '''
            }
        }

        stage('Deploy on Worker') {
            steps {
                sh '''
                echo "Skipping due to prior failure."
                '''
            }
        }
    }

    post {
        always {
            echo "Pipeline finished."
        }
    }
}