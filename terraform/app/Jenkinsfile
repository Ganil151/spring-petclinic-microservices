pipeline {
    agent { label params.NODE_LABEL }

    environment {
        COMPOSE_PROJECT_NAME = "spring-petclinic"
        DOCKER_IMAGE         = "ganil151/spring-petclinic-microservice"
        IMAGE_TAG            = "${env.BUILD_NUMBER ?: 'latest'}"
        // Add environment for ECR/Docker Hub credentials for the build-image step
        // We'll use this as a secure best practice instead of relying solely on the 'Docker Login' stage
        // NOTE: Replace 'my-docker-registry' with your actual ECR/Docker Hub
        DOCKER_REGISTRY_URL  = 'docker.io' 
        // NOTE: The JAVA_HOME environment is correctly defined in the Build Application stage
    }

    parameters {
        string(name: 'NODE_LABEL', defaultValue: 'worker-node', description: 'Label of the Jenkins worker node to run this pipeline')
        string(name: 'EC2_INSTANCE_NAME', defaultValue: 'Docker-Server', description: 'Name tag for the EC2 instance')
    }

    triggers {
        githubPush()
    }

    stages {
        stage('Checkout') {
            steps {
                git(
                    branch: 'main',
                    credentialsId: 'github-credentials',
                    url: 'https://github.com/Ganil151/spring-petclinic-microservices.git'
                )
            }
            post {
                always { echo "========Checkout========" }
                success { echo "========Checkout ⭐Successfully⭐========" }
                failure { echo "========Checkout failed❌========" }
            }
        }
        
        // **********************************************
        // FIX: Ensure mvnw has execute permission
        // **********************************************
        stage('Prepare Build') { 
             steps {
                sh 'chmod +x ./mvnw'
                // Optional: Check if the file is now executable
                sh 'ls -l ./mvnw'
             }
             post {
                success { echo "========Prepare Build ⭐Successfully⭐========" }
                failure { error("Failed to set execute permission on mvnw.") }
             }
        }

        stage('Install yq') { /* ... (Install yq stage remains the same) ... */ }
        stage('Remove genai-service from docker-compose.yml') { /* ... (Removal stage remains the same) ... */ }

        // Security Note: Docker Login is good for general image pushing, but the 
        // Spring Boot build-image goal can handle the registry login via settings.xml or environment.
        // We'll keep this stage for explicit security.
        stage('Docker Login') { /* ... (Docker Login stage remains the same) ... */ } 

        stage('Build Application') {
            // Your JAVA_HOME and PATH configuration is correct here, great job!
            environment {
                JAVA_HOME = "/usr/lib/jvm/java-21-amazon-corretto"
                PATH = "${JAVA_HOME}/bin:${env.PATH}"
            }
            steps {
                // We use clean install to compile, test, and package all JARs
                sh '''
                echo "Building the Spring PetClinic application..."
                ./mvnw clean install -DskipTests 
                '''
            }
            post {
                always { echo "========Build Application========" }
                success { echo "========Build Application ⭐Successfully⭐========" }
                failure { error("========Build Application failed❌========") }
            }
        }

        // **********************************************
        // ENHANCEMENT: Use the project's native way to build microservice images.
        // The original pipeline only built the config-server, which is insufficient.
        // The Petclinic project is designed to build images for ALL services.
        // **********************************************
        stage('Containerize All Microservices') {
            steps {
                script {
                    sh '''
                    echo "Containerizing and pushing all microservices to ${DOCKER_IMAGE}..."

                    # Set the registry property for the spring-boot-maven-plugin
                    export DOCKER_BUILD_TAG="${DOCKER_IMAGE}:${IMAGE_TAG}"
                    
                    # This command finds all pom.xml files, and for each microservice module (which 
                    # contains the spring-boot-maven-plugin), it builds and tags the Docker image.
                    # The image name will be the artifactId (e.g., customers-service)
                    ./mvnw spring-boot:build-image -P buildDocker -Dspring-boot.build-image.imageName="${DOCKER_IMAGE}/%s" -Dspring-boot.build-image.tag="${IMAGE_TAG}"
                    
                    # NOTE: If the above command fails to find all modules, use a loop (like in my previous response).
                    
                    # Since Docker Login was successful, we can push the individual images
                    echo "Pushing all newly built images..."
                    # Find all images tagged with the build number and push them
                    docker images --format "{{.Repository}}:{{.Tag}}" | grep "${IMAGE_TAG}" | while read IMAGE; do
                        docker push $IMAGE
                        docker tag $IMAGE "${IMAGE_IMAGE}:latest" # Also tag as latest
                        docker push "${IMAGE_IMAGE}:latest"
                    done
                    
                    echo "Successfully built and pushed all microservice images."
                    '''
                }
            }
            post {
                always { echo "========Docker Build and Push========" }
                success { echo "========Docker Build and Push ⭐Successfully⭐========" }
                failure { error("========Docker Build and Push failed❌========") }
            }
        }

        stage('EC2 Provisioning') { /* ... (EC2 Provisioning stage remains the same) ... */ }
        
    }
}